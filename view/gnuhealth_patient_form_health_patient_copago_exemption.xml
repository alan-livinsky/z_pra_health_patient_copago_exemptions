            string="Exenciones de copago"
            states="{'invisible': ~Eval('can_manage_copago_exemptions')}"
            colspan="4" col="12">
            <label name="copago_exempt_pregnant"/>
            <field name="copago_exempt_pregnant"/>
            <label name="copago_exempt_disabled"/>
            <field name="copago_exempt_disabled"/>
            <label name="copago_exempt_oncology"/>
            <field name="copago_exempt_oncology"/>
            <label name="copago_exempt_gynecology"/>
            <field name="copago_exempt_gynecology"/>
            <label name="copago_exempt_under_one_year"/>
            <field name="copago_exempt_under_one_year"/>
            <label name="copago_exempt_recent_surgery"/>
            <field name="copago_exempt_recent_surgery"/>
        </group>
        <newline/>
    </xpath>
</data>
